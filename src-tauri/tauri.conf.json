{
   "$schema": "https://schema.tauri.app/config/2",
   "productName": "Olib",
   "version": "3.2.1",
   "identifier": "com.shiyi0x7f.olibfluent",
   "build": {
      "beforeDevCommand": "npm run dev",
      "devUrl": "http://localhost:1420",
      "beforeBuildCommand": "npm run build",
      "frontendDist": "../dist"
   },
   "app": {
      "windows": [
         {
            "title": "Olib·开源图书",
            "width": 1000,
            "height": 700,
            "minWidth": 800,
            "minHeight": 600,
            "center": true,
            "decorations": true,
            "transparent": true
         }
      ],
      "security": {
         "csp": null
      }
   },
   "bundle": {
      "active": true,
      "targets": "all",
      "icon": [
         "icons/32x32.png",
         "icons/128x128.png",
         "icons/128x128@2x.png",
         "icons/icon.icns",
         "icons/icon.ico"
      ]
   }
}
